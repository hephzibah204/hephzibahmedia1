{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hephzibah-media",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hephzibah",
      "database_id": "b9c095e0-af42-40af-93c8-5da908033fd6"
    }
  ],
  "observability": {
    "enabled": true
  }
}
