tric-blue border border-electric-blue/30 px-3 py-1.5 rounded-full hover:bg-electric-blue hover:text-white transition-all animate-pulse\" href=\"/immersive\">Immersive Universe</a><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"#services\">Services<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/training\">Training<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/resources\">Resources<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/portfolio\">Company<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><a class=\"bg-electric-blue text-white px-6 py-2 text-sm font-bold uppercase tracking-wider hover:bg-electric-blue-lt transition-colors rounded-sm\" href=\"/contact\">Get Started</a></div><button class=\"lg:hidden text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main class=\"flex-grow\"><div class=\"pt-32 pb-32\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"mb-16 text-center\"><div class=\"flex items-center gap-4 mb-4 justify-center\" style=\"opacity:0;transform:none\"><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">Hephzibah Academy</span><span class=\"w-8 h-[1px] bg-electric-blue ml-4\"></span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Master Digital Skills That <span class=\"text-electric-blue\">Actually Pay</span></h2><p class=\"text-grey text-lg max-w-2xl leading-relaxed mx-auto\" style=\"opacity:0;transform:translateY(20px)\">Stop watching generic YouTube tutorials. Learn directly from an agency that builds high-ticket assets for top Nigerian brands.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-20\"><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/digital-marketing\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Become a Digital Marketing Expert</h3><p class=\"text-grey text-sm line-clamp-2\">Master full-funnel digital marketing in 12 weeks. Learn SEO, PPC, social media, email marketing, and analytics. Run real campaigns and graduate job-ready.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->12 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>SEO</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>PPC / Ads</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Social Media</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Email Marketing</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/web-design\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Build Professional Websites From Scratch</h3><p class=\"text-grey text-sm line-clamp-2\">Master HTML, CSS, and responsive design in our 8-week intensive program. Build real client-ready websites and launch your career as a professional web designer.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->8 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>HTML Fundamentals</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>CSS Foundations</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Responsive Design</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>CSS Grid &amp; Flexbox</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/seo\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Master Search Engine Optimization</h3><p class=\"text-grey text-sm line-clamp-2\">Learn to rank websites on Google Nigeria. Technical SEO, on-page optimization, link building, and local SEO strategies that drive organic traffic.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->8 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>SEO Fundamentals</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Technical SEO</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>On-Page SEO</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Link Building</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/graphics-design\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Master Visual Design That Stands Out</h3><p class=\"text-grey text-sm line-clamp-2\">Learn Adobe Photoshop, Illustrator, and Figma in our 10-week program. Create stunning brand identities, marketing materials, and digital assets that command premium prices.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->10 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Adobe Photoshop</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Adobe Illustrator</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Figma</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Adobe InDesign</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/ui-ux\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Design User-Centered Experiences</h3><p class=\"text-grey text-sm line-clamp-2\">Master UI/UX design with Figma. Learn user research, wireframing, prototyping, and design systems. Create interfaces users love.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->10 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Design Fundamentals</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Figma Mastery</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>User Research</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Wireframing</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/coding\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Become a Full-Stack Developer</h3><p class=\"text-grey text-sm line-clamp-2\">Master JavaScript, PHP, and modern web development. Build dynamic websites and applications from scratch. Launch your development career.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->12 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>JavaScript Fundamentals</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Advanced JavaScript</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>PHP &amp; Backend</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Full-Stack Projects</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-center py-4 text-xs font-bold uppercase tracking-widest group-hover:bg-electric-blue group-hover:border-electric-blue transition-all\">View Course Details</div></div></a><a class=\"group glass border border-white/5 hover:border-electric-blue/40 transition-all duration-500 flex flex-col h-full overflow-hidden\" href=\"/training/sales-funnel\"><div class=\"bg-midnight-mid border-b border-electric-blue/20 p-8 relative\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/10 transition-colors\"></div><span class=\"inline-block bg-electric-blue/10 text-electric-blue text-[10px] uppercase tracking-widest font-bold py-1 px-3 rounded-sm mb-4\">Enrolling Now</span><h3 class=\"text-xl font-bold text-white mb-2 group-hover:text-electric-blue transition-colors\">Build High-Converting Funnels</h3><p class=\"text-grey text-sm line-clamp-2\">Learn to build sales funnels that convert visitors into customers. Landing pages, email sequences, and automation.</p></div><div class=\"p-8 flex-grow flex flex-col\"><div class=\"flex gap-4 mb-6 pb-6 border-b border-white/5\"><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">⏱️ <!-- -->8 Weeks</div><div class=\"text-xs text-grey font-bold uppercase tracking-widest flex items-center gap-2\">💻 <!-- -->Physical</div></div><ul class=\"space-y-3 mb-8 flex-grow\"><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Funnel Fundamentals</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Landing Pages</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Email Automation</span></li><li class=\"text-sm text-cream flex items-start gap-2\"><span class=\"text-gold mt-1 text-xs\">✦</span><span>Offer Creation</span></li></ul><div class=\"mt-auto w-full border border-white/10 text-white text-cente