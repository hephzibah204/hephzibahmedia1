ectric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/resources\">Resources<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/portfolio\">Company<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><a class=\"bg-electric-blue text-white px-6 py-2 text-sm font-bold uppercase tracking-wider hover:bg-electric-blue-lt transition-colors rounded-sm\" href=\"/contact\">Get Started</a></div><button class=\"lg:hidden text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main class=\"flex-grow\"><div class=\"relative pt-32 pb-32 overflow-hidden\"><div class=\"absolute inset-0 z-0 pointer-events-none opacity-50\"><div style=\"position:relative;width:100%;height:100%;overflow:hidden;pointer-events:auto\"><div style=\"width:100%;height:100%\"><canvas style=\"display:block\"></canvas></div></div></div><section class=\"relative z-10 px-6 mb-24 max-w-5xl mx-auto text-center\"><div class=\"inline-flex items-center gap-2 text-electric-blue text-[10px] uppercase tracking-[0.2em] font-bold mb-6\"><span class=\"w-8 h-px bg-electric-blue\"></span>Business Digitalization<span class=\"w-8 h-px bg-electric-blue\"></span></div><h1 class=\"text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-8 leading-[1.1] tracking-tight\">Transform Your Business<!-- --> <em class=\"text-electric-blue not-italic\">Digitally</em></h1><p class=\"text-lg text-grey max-w-3xl mx-auto leading-relaxed mb-10\">Learn to digitize traditional businesses. E-commerce, digital payments, online presence, and automation for Nigerian businesses.</p><div class=\"flex flex-wrap items-center justify-center gap-6 text-sm uppercase tracking-widest text-grey font-bold\"><span class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar text-electric-blue\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg> <!-- -->6 Weeks</span><span class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-target text-electric-blue\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg> <!-- -->All Levels</span><span class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-play text-electric-blue\" aria-hidden=\"true\"><path d=\"M9 9.003a1 1 0 0 1 1.517-.859l4.997 2.997a1 1 0 0 1 0 1.718l-4.997 2.997A1 1 0 0 1 9 14.996z\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg> <!-- -->Online &amp; Physical</span></div></section><section class=\"bg-midnight-mid border-y border-white/5 py-24 mb-24\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"mb-16 text-center\"><div class=\"flex items-center gap-4 mb-4 justify-center\" style=\"opacity:0;transform:none\"><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">What You&#x27;ll Learn</span><span class=\"w-8 h-[1px] bg-electric-blue ml-4\"></span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Complete <span class=\"text-electric-blue\">Skill Stack</span></h2></div><div class=\"grid grid-cols-2 md:grid-cols-3 gap-4 mt-16\"><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">Digital Assessment</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Business analysis</p></div><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">Online Presence</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Google &amp; Social</p></div><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">E-commerce</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Selling online</p></div><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">Digital Payments</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Paystack &amp; Flutterwave</p></div><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">Cloud Tools</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Workspace &amp; Collaboration</p></div><div class=\"glass p-6 text-center border border-white/5 hover:border-electric-blue/30 transition-colors\"><h4 class=\"text-white font-bold mb-2 tracking-tight\">Automation</h4><p class=\"text-grey text-xs uppercase tracking-wider\">Scaling operations</p></div></div></div></section><section class=\"max-w-4xl mx-auto px-6 mb-24\"><div class=\"mb-16 \"><div class=\"flex items-center gap-4 mb-4 \" style=\"opacity:0;transform:translateX(-20px)\"><span class=\"w-8 h-[1px] bg-electric-blue\"></span><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">Syllabus</span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Course <span class=\"text-electric-blue\">Curriculum</span></h2></div><div class=\"space-y-4 mt-12\"><div class=\"bg-midnight-mid p-8 border-l-4 border-electric-blue flex flex-col md:flex-row gap-6 md:items-center\"><div class=\"bg-electric-blue text-white px-4 py-2 text-xs font-bold uppercase tracking-widest shrink-0 self-start md:self-center\">Week 1</div><div><h4 class=\"text-xl font-bold text-white mb-2\">Digital Assessment</h4><p class=\"text-grey text-sm leading-relaxed\">Analyze current business and identify digital opportunities.</p></div></div><div class=\"bg-midnight-mid p-8 border-l-4 border-electric-blue flex flex-col md:flex-row gap-6 md:items-center\"><div class=\"bg-electric-blue text-white px-4 py-2 text-xs font-bold uppercase tracking-widest shrink-0 self-start md:self-center\">Week 2-3</div><div><h4 class=\"text-xl font-bold text-white mb-2\">E-commerce &amp; Online Sales</h4><p class=\"text-grey text-sm leading-relaxed\">Setting up online stores and digital product delivery.</p></div></div><div class=\"bg-midnight-mid p-8 border-l-4 border-electric-blue flex flex-col md:flex-row gap-6 md:items-center\"><div class=\"bg-electric-blue text-white px-4 py-2 text-xs font-bold uppercase tracking-widest shrink-0 self-start md:self-center\">Week 4</div><div><h4 class=\"text-xl font-bold text-white mb-2\">Digital Payments</h4><p class=\"text-grey text-sm leading-relaxed\">Payment gateways, Flutterwave, Paystack integration.</p></div></div><div class=\"bg-midnight-mid p-8 border-l-4 border-electric-blue flex flex-col md:flex-row gap-6 md:items-center\"><div class=\"bg-electric-blue text-white px-4 py-2 text-xs font-bold uppercase tracking-widest shrink-0 self-start md:self-center\">Week 5-6</div><div><h4 class=\"text-xl font-bold text-white mb-2\">Automation &amp; Scaling</h4><p class=\"text-grey text-sm leading-relaxed\">Business automation tools and growth strategies.</p></div></div></div></section><section class=\"bg-midnight-mid border-y border-white/5 py-24 mb-24\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"mb-16 \"><div class=\"flex items-center gap-4 mb-4 \" style=\"opacity:0;transform:translateX(-20px)\"><span class=\"w-8 h-[1px] bg-electric-blue\"></span><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">Benefits</span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Why Choose <span class=\"text-electric-blue\">Hephzibah Academy</span></h2></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 mt-16\"><div class=\"glass p-8 border border-white/5 hover:border-electric-blue/30 transition-colors\"><h3 class=\"text-xl font-bold text-electric-blue mb-6\">Practical Skills</h3><ul class=\"space-y-4\"><li class=\"text-grey text-sm flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" st