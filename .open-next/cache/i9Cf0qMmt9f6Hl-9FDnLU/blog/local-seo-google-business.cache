ndefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L8\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n11:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",null,[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\n12:\"$W19\"\n13:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],null]}]\n15:[\"$\",\"div\",null,{\"className\":\"container mx-auto px-6 py-20 max-w-4xl\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-6xl font-bold mb-6\",\"children\":\"Untitled\"}],[\"$\",\"p\",null,{\"className\":\"text-gold mb-10\",\"children\":\"$undefined\"}],[\"$\",\"div\",null,{\"className\":\"prose prose-invert prose-lg max-w-none\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"mb-4\",\"children\":\"---\\r\"}],[\"$\",\"p\",\"1\",{\"className\":\"mb-4\",\"children\":\"title: \\\"Local SEO for Nigerian Businesses: Dominate Google Maps & Business Profiles\\\"\\r\"}],[\"$\",\"p\",\"2\",{\"className\":\"mb-4\",\"children\":\"date: \\\"2025-01-15T00:00:00Z\\\"\\r\"}],[\"$\",\"p\",\"3\",{\"className\":\"mb-4\",\"children\":\"description: \\\"Complete local SEO guide. Optimize your Google Business Profile, citations, and location pages to rank in Nigerian Google Maps.\\\"\\r\"}],[\"$\",\"p\",\"4\",{\"className\":\"mb-4\",\"children\":\"---\\r\"}],[\"$\",\"br\",\"5\",{}],[\"$\",\"p\",\"6\",{\"className\":\"mb-4\",\"children\":\"Hephzibah Media\\r\"}],[\"$\",\"br\",\"7\",{}],[\"$\",\"p\",\"8\",{\"className\":\"mb-4\",\"children\":\"      - [Services](index.html#services)\\r\"}],[\"$\",\"br\",\"9\",{}],[\"$\",\"p\",\"10\",{\"className\":\"mb-4\",\"children\":\"      - [About](about.html)\\r\"}],[\"$\",\"br\",\"11\",{}],[\"$\",\"p\",\"12\",{\"className\":\"mb-4\",\"children\":\"      - [Landing Pages](landing-pages-sales-funnels.html)\\r\"}],[\"$\",\"br\",\"13\",{}],[\"$\",\"p\",\"14\",{\"className\":\"mb-4\",\"children\":\"      - [Training](training.html)\\r\"}],[\"$\",\"br\",\"15\",{}],[\"$\",\"p\",\"16\",{\"className\":\"mb-4\",\"children\":\"      - [Get a Quote](contact.html\\\" class=\\\"nav-cta)\\r\"}],[\"$\",\"br\",\"17\",{}],[\"$\",\"br\",\"18\",{}],[\"$\",\"br\",\"19\",{}],[\"$\",\"br\",\"20\",{}],[\"$\",\"br\",\"21\",{}],[\"$\",\"br\",\"22\",{}],[\"$\",\"br\",\"23\",{}],[\"$\",\"p\",\"24\",{\"className\":\"mb-4\",\"children\":\"      Local SEO · 10 min read\\r\"}],[\"$\",\"p\",\"25\",{\"className\":\"mb-4\",\"children\":\"      # Local SEO for Nigerian Businesses: Dominate Google Maps & Business Profiles\\r\"}],[\"$\",\"br\",\"26\",{}],[\"$\",\"p\",\"27\",{\"className\":\"mb-4\",\"children\":\"      By Hephzibah Media Team · Published December 22, 2024\\r\"}],[\"$\",\"p\",\"28\",{\"className\":\"mb-4\",\"children\":\"      Local SEO wins the 'near me' searches. When someone searches 'web design Lagos' or 'printing services Abuja,' Google shows map results + local businesses. Here's exactly how to rank at the top of those results.\\r\"}],[\"$\",\"br\",\"29\",{}],[\"$\",\"br\",\"30\",{}],[\"$\",\"br\",\"31\",{}],[\"$\",\"br\",\"32\",{}],[\"$\",\"br\",\"33\",{}],[\"$\",\"p\",\"34\",{\"className\":\"mb-4\",\"children\":\"      ## Claim & Optimize Your Google Business Profile\\r\"}],[\"$\",\"br\",\"35\",{}],[\"$\",\"br\",\"36\",{}],[\"$\",\"p\",\"37\",{\"className\":\"mb-4\",\"children\":\"1. Go to google.com/business, search your business name. 2. If it exists, claim it. If not, create it. 3. Complete 100% of the profile: all photos, description, hours, services, website. 4. Add 1015 photos (office, team, past work, before-afters). 5. Verify via postcard (23 weeks) or phone (instant). Verified profiles rank 23× higher.\\r\"}],[\"$\",\"br\",\"38\",{}],[\"$\",\"p\",\"39\",{\"className\":\"mb-4\",\"children\":\"      ## NAP Consistency Across the Web\\r\"}],[\"$\",\"br\",\"40\",{}],[\"$\",\"br\",\"41\",{}],[\"$\",\"p\",\"42\",{\"className\":\"mb-4\",\"children\":\"NAP = Name, Address, Phone. Every mention of your business must be identical: same spelling, same format. Create citations on: Google Business, Bing Places, Nigerian directories (VConnect, BusinessList.com.ng, Jumia Services). Update all of them if you move. Inconsistent NAP = lower local rankings.\\r\"}],[\"$\",\"br\",\"43\",{}],[\"$\",\"p\",\"44\",{\"className\":\"mb-4\",\"children\":\"      ## Location Pages with Unique Content\\r\"}],[\"$\",\"br\",\"45\",{}],[\"$\",\"br\",\"46\",{}],[\"$\",\"p\",\"47\",{\"className\":\"mb-4\",\"children\":\"If you serve multiple cities (Lagos, Abuja, Ikeja), create a unique page for each. Not just swapping the city name  genuinely different content: local testimonials, local case studies, community involvement. Example: 'Web Design in Lagos' page mentions Lekki-specific clients; 'Web Design in Abuja' page mentions GRA Abuja clients.\\r\"}],[\"$\",\"br\",\"48\",{}],[\"$\",\"p\",\"49\",{\"className\":\"mb-4\",\"children\":\"      ## Build Local Backlinks\\r\"}],[\"$\",\"br\",\"50\",{}],[\"$\",\"br\",\"51\",{}],[\"$\",\"p\",\"52\",{\"className\":\"mb-4\",\"children\":\"Get mentioned on Nigerian media sites, blogs, and business networks. Write a guest post for a Lagos business blog. Sponsor a local event (gets mentioned on their website). Partner with complementary businesses who link to you. Local links signal 'this business serves this community.'\\r\"}],\"$L1e\",\"$L1f\",\"$L20\",\"$L21\",\"$L22\",\"$L23\",\"$L24\",\"$L25\",\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\",\"$L2b\",\"$L2c\",\"$L2d\",\"$L2e\",\"$L2f\",\"$L30\",\"$L31\",\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\",\"$L3e\",\"$L3f\",\"$L40\",\"$L41\",\"$L42\",\"$L43\",\"$L44\",\"$L45\",\"$L46\",\"$L47\",\"$L48\",\"$L49\",\"$L4a\",\"$L4b\",\"$L4c\",\"$L4d\",\"$L4e\",\"$L4f\",\"$L50\",\"$L51\",\"$L52\",\"$L53\",\"$L54\",\"$L55\",\"$L56\",\"$L57\",\"$L58\",\"$L59\",\"$L5a\",\"$L5b\",\"$L5c\",\"$L5d\",\"$L5e\",\"$L5f\",\"$L60\",\"$L61\",\"$L62\",\"$L63\",\"$L64\",\"$L65\",\"$L66\",\"$L67\",\"$L68\",\"$L69\",\"$L6a\",\"$L6b\",\"$L6c\",\"$L6d\",\"$L6e\"]}]]}]\n1e:[\"$\",\"br\",\"53\",{}]\n1f:[\"$\",\"p\",\"54\",{\"className\":\"mb-4\",\"children\":\"      ## Reviews: The Local SEO Multiplier\\r\"}]\n20:[\"$\",\"br\",\"55\",{}]\n21:[\"$\",\"br\",\"56\",{}]\n22:[\"$\",\"p\",\"57\",{\"className\":\"mb-4\",\"children\":\"Google prioritises businesses with recent 5-star reviews. Aim for 40+ reviews (threshold for competitive rankings). After every project, email customers: 'We'd love your feedback on Google [link].' Respond to every review (positive and negative). Reviews also influence CTR  4.5? businesses get 25% more clicks than 3.5?.\\r\"}]\n23:[\"$\",\"br\",\"58\",{}]\n24:[\"$\",\"p\",\"59\",{\"className\":\"mb-4\",\"children\":\"      ## Question & Answer Management\\r\"}]\n25:[\"$\",\"br\",\"60\",{}]\n26:[\"$\",\"br\",\"61\",{}]\n27:[\"$\",\"p\",\"62\",{\"className\":\"mb-4\",\"children\":\"Go to your Google Business Profile, add FAQs. Customers see these before they call or visit. Example: 'How much does web design cost?' 'Do you offer payment plans?' Answer in 23 sentences, clearly. This also helps Google understand your business better.\\r\"}]\n28:[\"$\",\"br\",\"63\",{}]\n29:[\"$\",\"p\",\"64\",{\"className\":\"mb-4\",\"children\":\"      ## Local Schema Markup\\r\"}]\n2a:[\"$\",\"br\",\"65\",{}]\n2b:[\"$\",\"br\",\"66\",{}]\n2c:[\"$\",\"p\",\"67\",{\"className\":\"mb-4\",\"children\":\"Add LocalBusiness schema to your website (already done in these templates). Include: address, phone, hours, service areas. If you serve 10 cities, add ServiceArea schema listing all of them. This helps Google understand your service radius.\\r\"}]\n2d:[\"$\",\"br\",\"68\",{}]\n2e:[\"$\",\"br\",\"69\",{}]\n2f:[\"$\",\"br\",\"70\",{}]\n30:[\"$\",\"br\",\"71\",{}]\n31:[\"$\",\"br\",\"72\",{}]\n32:[\"$\",\"p\",\"73\",{\"className\":\"mb-4\",\"children\":\"    ## Ready for Growth?\\r\"}]\n33:[\"$\",\"br\",\"74\",{}]\n34:[\"$\",\"br\",\"75\",{}]\n35:[\"$\",\"p\",\"76\",{\"className\":\"mb-4\",\"children\":\"Let our team audit your current marketing strategy and show you exactly what's holding you back.\\r\"}]\n36:[\"$\",\"br\",\"77\",{}]\n37:[\"$\",\"p\",\"78\",{\"className\":\"mb-4\",\"children\":\"    [Start Your Free Audit](contact.html\\\" class=\\\"btn-primary)\\r\"}]\n38:[\"$\",\"br\",\"79\",{}]\n39:[\"$\",\"br\",\"80\",{}]\n3a:[\"$\",\"br\",\"81\",{}]\n3b:[\"$\",\"br\",\"82\",{}]\n3c:[\"$\",\"br\",\"83\",{}]\n3d:[\"$\",\"p\",\"84\",{\"className\":\"mb-4\",\"children\":\"        Hephzibah Media\\r\"}]\n3e:[\"$\",\"br\",\"85\",{}]\n3f:[\"$\",\"p\",\"86\",{\"className\":\"mb-4\",\"children\":\"Nigeria's premium Digital Marketing, Tech & Print Agency. Building brands that dominate from Ogere, Ogun State.\\r\"}]\n40:[\"$\",\"br\",\"87\",{}]\n41:[\"$\",\"p\",\"88\",{\"className\":\"mb-4\",\"children\":\"        Old Ode Road, Along Ogere Tollgate, Ogere, Nigeria\\r\"}]\n42:[\"$\",\"br\",\"89\",{}]\n43:[\"$\",\"br\",\"90\",{}]\n44:[\"$\",\"p\",\"91\",{\"className\":\"mb-4\",\"children\":\"        Services\\r\"}]\n45:[\"$\",\"br\",\"92\",{}]\n46:[\"$\",\"p\",\"93\",{\"className\":\"mb-4\",\"children\":\"          - [Web Design](web-design.html)\\r\"}]\n47:[\"$\",\"br\",\"94\",{}]\n48:[\"$\",\"p\",\"95\",{\"className\":\"mb-4\",\"children\":\"          - [Digital Marketing](digital-marketing.html)\\r\"}]\n49:[\"$\",\"br\",\"96\",{}]\n4a:[\"$\",\"p\",\"97\",{\"className\":\"mb-4\",\"children\":\"          - [SEO](seo.html)\\r\"}]\n4b:[\"$\",\"br\",\"98\",{}]\n4c:[\"$\",\"p\",\"99\",{\"className\":\"mb-4\",\"children\":\"          - [Graphics Design](graphics-design.html)\\r\"}]\n4d:[