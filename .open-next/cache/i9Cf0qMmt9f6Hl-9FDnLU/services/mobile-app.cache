p;w=1080&amp;q=75 1080w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75\"/></div></a><div class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[10px] font-bold text-electric-blue border border-electric-blue/30 px-3 py-1.5 rounded-full hover:bg-electric-blue hover:text-white transition-all animate-pulse\" href=\"/immersive\">Immersive Universe</a><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"#services\">Services<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/training\">Training<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/resources\">Resources<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/portfolio\">Company<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><a class=\"bg-electric-blue text-white px-6 py-2 text-sm font-bold uppercase tracking-wider hover:bg-electric-blue-lt transition-colors rounded-sm\" href=\"/contact\">Get Started</a></div><button class=\"lg:hidden text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main class=\"flex-grow\"><div class=\"pt-24 relative overflow-hidden\"><div class=\"absolute inset-0 z-0 pointer-events-none opacity-50\"><div style=\"position:relative;width:100%;height:100%;overflow:hidden;pointer-events:auto\"><div style=\"width:100%;height:100%\"><canvas style=\"display:block\"></canvas></div></div></div><section class=\"relative py-24 md:py-32 overflow-hidden border-b border-white/5\"><div class=\"absolute inset-0 bg-radial-[at_50%_0%] from-electric-blue/10 via-transparent to-transparent pointer-events-none\"></div><div class=\"max-w-7xl mx-auto px-6 relative z-10 text-center\"><div class=\"inline-flex items-center gap-3 px-4 py-2 bg-midnight-mid border border-white/10 rounded-full mb-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-smartphone text-electric-blue\" aria-hidden=\"true\"><rect width=\"14\" height=\"20\" x=\"5\" y=\"2\" rx=\"2\" ry=\"2\"></rect><path d=\"M12 18h.01\"></path></svg><span class=\"text-[10px] uppercase tracking-[0.2em] font-bold text-grey\">Mobile App Development Nigeria</span></div><h1 class=\"text-5xl md:text-7xl font-bold text-white mb-8 tracking-tighter leading-tight max-w-4xl mx-auto\">Mobile Apps Engineered for Nigeria&#x27;s Mobile-First Market</h1><p class=\"text-grey text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed\">iOS and Android apps built for performance on local networks. From MVP validation to store launch, we handle design, development, and submission for the Nigerian market.</p><div class=\"flex flex-wrap justify-center gap-12 pt-8 border-t border-white/10\"><div class=\"text-center\"><div class=\"text-3xl font-bold text-white mb-1 font-mono\">40+</div><div class=\"text-[10px] uppercase tracking-widest text-grey\">Apps Developed</div></div><div class=\"text-center\"><div class=\"text-3xl font-bold text-white mb-1 font-mono\">100%</div><div class=\"text-[10px] uppercase tracking-widest text-grey\">Offline-Ready</div></div><div class=\"text-center\"><div class=\"text-3xl font-bold text-white mb-1 font-mono\">4.8/5</div><div class=\"text-[10px] uppercase tracking-widest text-grey\">Avg Rating</div></div></div></div></section><section class=\"py-32 bg-midnight-mid\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"mb-16 \"><div class=\"flex items-center gap-4 mb-4 \" style=\"opacity:0;transform:translateX(-20px)\"><span class=\"w-8 h-[1px] bg-electric-blue\"></span><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">The Challenge</span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Stop Settling for Weak Results</h2><p class=\"text-grey text-lg max-w-2xl leading-relaxed \" style=\"opacity:0;transform:translateY(20px)\">Many Nigerian businesses struggle to gain traction online due to outdated strategies and poor execution. Recognize these bottlenecks?</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-1 bg-white/5 border border-white/5\"><div class=\"bg-midnight p-8 hover:bg-midnight-lt transition-colors\"><h3 class=\"text-white font-bold mb-4 tracking-tight\">Slow &amp; Buggy Performance</h3><p class=\"text-grey text-sm leading-relaxed\">Apps that crash on low-end devices or load forever on 3G drive customers away.</p></div><div class=\"bg-midnight p-8 hover:bg-midnight-lt transition-colors\"><h3 class=\"text-white font-bold mb-4 tracking-tight\">No Offline Capability</h3><p class=\"text-grey text-sm leading-relaxed\">Connectivity is variable in Nigeria. If your app requires constant internet, it fails when users need it most.</p></div><div class=\"bg-midnight p-8 hover:bg-midnight-lt transition-colors\"><h3 class=\"text-white font-bold mb-4 tracking-tight\">Poor User Experience</h3><p class=\"text-grey text-sm leading-relaxed\">Clunky navigation and flows that don&#x27;t account for local behavior lead to high uninstall rates.</p></div><div class=\"bg-midnight p-8 hover:bg-midnight-lt transition-colors\"><h3 class=\"text-white font-bold mb-4 tracking-tight\">Single Platform Only</h3><p class=\"text-grey text-sm leading-relaxed\">Being only on Android or iOS limits your market reach. You need both to dominate.</p></div></div></div></section><section class=\"py-32 border-y border-white/5 relative overflow-hidden\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-radial-[at_50%_50%] from-electric-blue/5 to-transparent pointer-events-none\"></div><div class=\"max-w-7xl mx-auto px-6 relative z-10\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\"><div><div class=\"mb-16 \"><div class=\"flex items-center gap-4 mb-4 \" style=\"opacity:0;transform:translateX(-20px)\"><span class=\"w-8 h-[1px] bg-electric-blue\"></span><span class=\"text-[10px] uppercase tracking-[0.3em] text-electric-blue font-bold\">Our Approach</span></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-tight\" style=\"opacity:0;transform:translateY(20px)\">Strategy Built for the Local Market</h2><p class=\"text-grey text-lg max-w-2xl leading-relaxed \" style=\"opacity:0;transform:translateY(20px)\">We don&#x27;t do generic. Our methodology is refined for the unique behavior of Nigerian consumers and the local competitive landscape.</p></div><ul class=\"space-y-6 mt-12\"><li class=\"flex gap-4 items-start group\"><div class=\"mt-1 text-electric-blue group-hover:scale-110 transition-transform\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg></div><span class=\"text-grey text-lg leading-relaxed\">Product discovery to define MVP and core user flows</span></li><li class=\"flex gap-4 items-start group\"><div class=\"mt-1 text-electric-blue group-hover:scale-110 transition-transform\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg></div><span class=\"text-grey text-lg leading-relaxed\">UI/UX designed for Nigerian mobile behavior patterns</span></li><li class=\"flex gap-4 items-start group\"><div class=\"mt-1 text-electric-blue group-hover:scale-110 transition-transform\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg></div><span class=\"text-grey text-lg leading-relaxed\">Cross-platform development with React Native for speed and reach</span></li><li class=\"flex gap-4 items-start group\"><div class=\"mt-1 text-electric-blue group-hover:scale-110 transition-transform\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg></div><span class=\"text-grey text-lg leading-relaxed\">Offline-first architecture with local data sync capabilities</span></li><li class=\"flex gap-4 items-start group\"><div class=\"mt-1 text-electric-blue group-hover:scale-110 transition-transform\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg></div><span class=\"text-grey text-lg leading-relaxed\">Performance testing on budget devices and 3G networks</span></li></ul></div><div class=\"glass p-12 lg:p-16\"><h3 class=\"text-2xl font-bold text-white mb-8\">What You Get</h3><div class=\"space-y-10\"><div><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-3xl\">📱</span><h4 class=\"text-white font-bold tracking-tight\">App Development</h4></div><ul class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 pl-12\"><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->React Native Cross-Platform</li><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->Native iOS &amp; Android builds</li><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->PWA (Progressive Web App)</li></ul></div><div><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-3xl\">☁️</span><h4 class=\"text-white font-bold tracking-tight\">Backend &amp; Security</h4></div><ul class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 pl-12\"><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->Offline-first data sync</li><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->Secure JWT Authentication</li><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->Push notification system</li></ul></div><div><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-3xl\">🚀</span><h4 class=\"text-white font-bold tracking-tight\">Launch &amp; Support</h4></div><ul class=\"grid grid-cols-1 sm:grid-cols-2 gap-3 pl-12\"><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->App Store Submission</li><li class=\"text-grey text-xs flex items-center gap-2\"><span class=\"w-1 h-1 bg-electric-blue rounded-full\"></span> <!-- -->Play Store compliance</li><li class=\"text-grey te