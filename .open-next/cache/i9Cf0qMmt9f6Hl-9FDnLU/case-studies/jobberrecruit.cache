ll,{\"className\":\"text-2xl font-display text-white mb-4\",\"children\":\"The Problem\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"The modern job market is highly fragmented. Employers waste hours filtering unqualified applicants across disparate tools, while candidates lack access to upskilling resources, professional CV reviews, and interview prep.\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3 text-grey\",\"children\":[[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Fragmented tools for posting, messaging, and applicant tracking.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Unqualified talent pools applying blindly, bloating pipelines.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Candidates lacking affordable CV reviews, mock interviews, and courses.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Rigid payment structures and weak SEO/security in regional job boards.\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-16\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"Our Approach\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"We designed JobberRecruit with a \\\"Candidate-First, Employer-Optimized\\\" philosophy, building the platform around three core principles:\"}],\"$L15\"]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\"]}]]}],null,\"$L1a\"]}]\n1b:[]\n12:\"$W1b\"\n13:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1c\",null,{\"children\":\