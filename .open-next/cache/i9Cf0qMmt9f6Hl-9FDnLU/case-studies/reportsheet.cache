 border-t border-white/10\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Client\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Schools & Teachers\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Product\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"ReportSheet.com.ng\"}]]}],[\"$\",\"div\",null,{\"className\":\"col-span-2\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Deliverables\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Web Platform, PHP REST API, Multi-Role Portals\"}]]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"max-w-4xl mx-auto px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"glass p-8 md:p-12 rounded-xl mb-12\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-display text-white mb-4\",\"children\":\"The Problem\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"Managing student records and grading continuous assessments is historically tedious. Administrators are forced to choose between complex, expensive software or fragile spreadsheets. With varying internet reliability, cloud-only platforms frequently lead to data loss during critical grading periods.\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3 text-grey\",\"children\":[[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Cumbersome manual compilation leading to human errors.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Spotty internet causing data loss on heavy Single Page Applications.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" High hosting costs forcing schools onto shared cPanel environments.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"✗\"}],\" Lack of granular access control exposing sensitive admin settings.\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-16\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"Our Approach\"}],\"$L15\",\"$L16\"]}],\"$L17\",\"$L18\",\"$L19\",\"$L1a\"]}]]}],null,\"$L1b\"]}]\n1c:[]\n12:\"$W1c\"\n13:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1d\",null,{\"children\":\"$L1e\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1f\",null,{\"children\":[\"$\",\"$20\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L21\"}]}]}],null]}]\n22:I[484,[],\"OutletBoundary\"]\n15:[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"Before writing code, we studied the frantic \\\"result season\\\" workflows of form teachers and administrators. We focused on three guiding principles:\"}]\n16:[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-3 gap-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Deployment Flexibility\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"Easily deployable on local networks (Docker/SQLite) or cheap shared hosting.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Resilient Data Entry\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"Browser caching ensures teachers never lose grades if the network drops.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Role-Specific Workflows\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"Isolated portals tailored specifically to what each role needs to see.\"}]]}]]}]\n17:[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"What We Built\"}]\n18:[\"$\",\"div\",null,{\"className\":\"space-y-12 mb-16\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"🏫\"}],\" Multi-Role Portal Architecture\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"The frontend is split into distinct portals: an Admin Panel for centralized management, a Teacher Portal for seamless score input, and a read-only Student/Parent Portal for checking and printing finalized report cards.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"📝\"}],\" Integrated Exam Maker\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"We built an exammaker.html module allowing teachers to craft, format, and store standardized exams and continuous assessments natively within the platform.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"⚡\"}],\" Resilient, Cache-First Frontend\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"Built on static HTML/JS/CSS, the UI intelligently caches data in browser storage to maintain responsiveness. A decoupled config allows it to seamlessly point to local or cloud APIs depending on the deployment.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"🛡️\"}],\" Enterprise-Grade Security\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"Features comprehensive audit logging for every critical action, ensuring complete traceability for grading disputes, plus 2FA and role-based subscription models to secure administrative accounts.\"}]]}]]}]\n19:[\"$\",\"div\",null,{\"className\":\"glass p-8 md:p-12 rounded-xl mb-16\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-display text-white mb-6\",\"children\":\"Results & Impact\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 md:grid-cols-4 gap-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-3xl font-display text-electric-blue font-bold mb-1\",\"children\":\"Zero\"}],[\"$\",\"div\",null,{\"className\":\"text-xs text-grey uppercase tracking-wider\",\"children\":\"Data Loss\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-3xl font-display text-electric-blue font-bold mb-1\",\"children\":\"100%\"}],[\"$\",\"div\",null,{\"className\":\"text-xs text-grey uppercase tracking-wider\",\"children\":\"cPanel Compatible\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-3xl font-display text-electric-blue font-bold mb-1\",\"children\":\"3\"}],[\"$\",\"div\",null,{\"className\":\"