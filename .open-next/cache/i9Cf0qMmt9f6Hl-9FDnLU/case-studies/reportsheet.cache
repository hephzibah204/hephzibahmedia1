position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Ficon.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Ficon.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Ficon.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Ficon.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Ficon.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Ficon.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Ficon.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Ficon.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Ficon.png&amp;w=3840&amp;q=75\"/></div></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"relative z-10 flex flex-col min-h-screen\"><nav class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent py-6\"><div class=\"max-w-7xl mx-auto px-6 flex items-center justify-between\"><a class=\"flex items-center gap-3 group\" href=\"/\"><div class=\"relative w-16 h-16 md:w-20 md:h-20 overflow-hidden\"><img alt=\"Hephzibah Media Logo\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain group-hover:scale-110 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75\"/></div></a><div class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[10px] font-bold text-electric-blue border border-electric-blue/30 px-3 py-1.5 rounded-full hover:bg-electric-blue hover:text-white transition-all animate-pulse\" href=\"/immersive\">Immersive Universe</a><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"#services\">Services<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/training\">Training<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/resources\">Resources<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/portfolio\">Company<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><a class=\"bg-electric-blue text-white px-6 py-2 text-sm font-bold uppercase tracking-wider hover:bg-electric-blue-lt transition-colors rounded-sm\" href=\"/contact\">Get Started</a></div><button class=\"lg:hidden text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main class=\"flex-grow\"><div class=\"pt-32 pb-20\"><section class=\"max-w-4xl mx-auto px-6 mb-16\"><a class=\"text-electric-blue text-sm uppercase tracking-wider mb-8 inline-block hover:text-white transition-colors\" href=\"/case-studies\">← Back to Case Studies</a><div class=\"flex flex-wrap gap-2 mb-6\"><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">EdTech</span><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">SaaS</span><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">Web Application</span></div><h1 class=\"text-4xl md:text-6xl font-display font-bold text-white mb-6 leading-tight\">Modernising School Result Management &amp; Assessment in Nigeria</h1><p class=\"text-xl text-grey leading-relaxed\">ReportSheet.com.ng is a lightweight, cPanel-friendly, and highly responsive school report-card system designed for the realities of the local education sector, ensuring a seamless grading experience even in low-bandwidth environments.</p><div class=\"grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-12 border-t border-white/10\"><div><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Client</p><p class=\"text-white font-medium\">Schools &amp; Teachers</p></div><div><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Product</p><p class=\"text-white font-medium\">ReportSheet.com.ng</p></div><div class=\"col-span-2\"><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Deliverables</p><p class=\"text-white font-medium\">Web Platform, PHP REST API, Multi-Role Portals</p></div></div></section><section class=\"max-w-4xl mx-auto px-6\"><div class=\"glass p-8 md:p-12 rounded-xl mb-12\"><h2 class=\"text-2xl font-display text-white mb-4\">The Problem</h2><p class=\"text-grey leading-relaxed mb-6\">Managing student records and grading continuous assessments is historically tedious. Administrators are forced to choose between complex, expensive software or fragile spreadsheets. With varying internet reliability, cloud-only platforms frequently lead to data loss during critical grading periods.</p><ul class=\"space-y-3 text-grey\"><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">✗</span> Cumbersome manual compilation leading to human errors.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">✗</span> Spotty internet causing data loss on heavy Single Page Applications.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">✗</span> High hosting costs forcing schools onto shared cPanel environments.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">✗</span> Lack of granular access control exposing sensitive admin settings.</li></ul></div><div class=\"mb-16\"><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">Our Approach</h2><p class=\"text-grey leading-relaxed mb-6\">Before writing code, we studied the frantic &quot;result season&quot; workflows of form teachers and administrators. We focused on three guiding principles:</p><div class=\"grid md:grid-cols-3 gap-6\"><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Deployment Flexibility</h3><p class=\"text-sm text-grey\">Easily deployable on local networks (Docker/SQLite) or cheap shared hosting.</p></div><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Resilient Data Entry</h3><p class=\"text-sm text-grey\">Browser caching ensures teachers never lose grades if the network drops.</p></div><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Role-Specific Workflows</h3><p class=\"text-sm text-grey\">Isolated portals tailored specifically to what each role needs to see.</p></div></div></div><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">What We Built</h2><div class=\"space-y-12 mb-16\"><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">🏫</span> Multi-Role Portal Architecture</h3><p class=\"text-grey leading-relaxed mb-4\">The frontend is split into distinct portals: an Admin Panel for centralized management, a Teacher Portal for seamless score input, and a read-only Student/Parent Portal for checking and printing finalized report cards.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">📝</span> Integrated Exam Maker</h3><p class=\"text-grey leading-relaxed mb-4\">We built an exammaker.html module allowing teachers to craft, format, and store standardized exams and continuous assessments natively within the platform.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">⚡</span> Resilient, Cache-First Frontend</h3><p class=\"text-grey leading-relaxed mb-4\">Built on static HTML/JS/CSS, the UI intelligently caches data in browser storage to maintain responsiveness. A decoupled config allows it to seamlessly point to local or cloud APIs depending on the deployment.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">🛡️</span> Enterprise-Grade Security</h3><p class=\"text-grey leading-relaxed mb-4\">Features comprehensive audit logging for every critical action, ensuring complete traceability for grading disputes, plus 2FA and role-based subscription models to secure administrative accounts.</p></div></div><div class=\"glass p-8 md:p-12 rounded-xl mb-16\"><h2 class=\"text-2xl font-display text-white mb-6\">Results &amp; Impact</h2><div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\"><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">Zero</div><div class=\"text-xs text-grey uppercase tracking-wider\">Data Loss</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">100%</div><div class=\"text-xs text-grey uppercase tracking-wider\">cPanel Compatible</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">3</div><div class=\"text-xs text-grey uppercase tracking-wider\">Isolated Portals</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">1st</div><div class=\"text-xs text-grey uppercase tracking-wider\">Offline-First Engine</div></div></div></div><div><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">The Architecture</h2><div class=\"bg-black/50 border border-white/10 p-6 rounded-lg font-mono text-sm text-electric-blue-lt overflow-x-auto whitespace-pre\">┌────────────────────────────────────────────────────┐\n│              Static Frontend (HTML/JS/CSS)         │\n│         Browser Caching · Role-based Portals       │\n└──────────────────────┬─────────────────────────────┘\n                       │\n┌──────────────────────▼─────────────────────────────┐\n│                Shared Hosting / cPanel             │\n│  ┌─────────────────────────────────────────────┐   │\n│  │                PHP REST API                 │   │\n│  │       JWT Auth · Swagger API Docs           │   │\n│  └──────────┬──────────────┬───────────────────┘   │\n│             │              │                       │\n│    ┌────────▼──────┐  ┌────▼───────────────────┐   │\n│    │     SQLite    │  │     MySQL/MariaDB      │   │\n│    │ (Local/Docker)│  │      (Production)      │   │\n│    └───────────────┘  └────────────────────────┘   │\n└────────────────────────────────────────────────────┘</div></div></section></div><!--$--><!--/$--></main><footer class=\"bg-midnight-mid border-t border-white/10 pt-20 pb-10\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\"><div class=\"space-y-6\"><a class=\"flex items-center gap-3 group\" href=\"/\"><div class=\"relative w-8 h-8 overflow-hidden\"><img alt=\"Hephzibah Media Logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain group-hover:scale-110 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1200&amp;q=