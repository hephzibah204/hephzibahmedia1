xl text-grey leading-relaxed\",\"children\":\"Solen is a full-featured AI wellness coach providing conversational, empathetic guidance 24/7. Engineered as a complete \\\"business in a box\\\" with user authentication, subscription management, a bespoke admin dashboard, and an integrated blog CMS.\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-12 border-t border-white/10\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Client\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Solen\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Product\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Solen Platform\"}]]}],[\"$\",\"div\",null,{\"className\":\"col-span-2\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Deliverables\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Full-Stack Web App, AI Wellness Coach, Custom CMS\"}]]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"max-w-4xl mx-auto px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"glass p-8 md:p-12 rounded-xl mb-12\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-display text-white mb-4\",\"children\":\"The Problem\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"The wellness app market is saturated with generic mood trackers and static content. Users need dynamic responses tailored to their emotional state. Moreover, running a SaaS typically requires complex DevOps, containerisation, and high server costs just to get off the ground.\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3 text-grey\",\"children\":[[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" Generic, cookie-cutter advice instead of dynamic, contextual responses.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" Complex onboarding deterring users seeking immediate help.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" High operational overhead stitching together multiple expensive SaaS tools.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" JavaScript-heavy stacks requiring complex DevOps and high server costs.\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-16\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"Our Approach\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"We designed Solen with a philosophy of maximum impact with minimum architectural friction. Rather than adopting a complex microservices architecture, we opted for a highly optimised monolithic approach to keep running costs incredibly low while delivering a highly interactive, React-powered frontend.\"}],\"$L15\"]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\"]}]]}],null,\"$L1a\"]}]\n1b:[]\n12:\"$W1b\"\n13:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1c\",null,{\"children\":\"$L1d\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1e\",null,{\"children\":[\"$\",\"$1f\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L20\"}]}]}],null]}]\n21:I[484,[],\"OutletBoundary\"]\n15:[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-3 gap-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg