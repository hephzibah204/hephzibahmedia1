ull,{\"className\":\"pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-grey tracking-wider uppercase\",\"children\":[[\"$\",\"p\",null,{\"children\":\"В© 2026 Hephzibah Media. All rights reserved.\"}],[\"$\",\"div\",null,{\"className\":\"flex gap-6\",\"children\":[[\"$\",\"$L9\",null,{\"href\":\"/privacy\",\"className\":\"hover:text-white\",\"children\":\"Privacy Policy\"}],[\"$\",\"$L9\",null,{\"href\":\"/terms\",\"className\":\"hover:text-white\",\"children\":\"Terms of Service\"}]]}]]}]\nf:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L7\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L8\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n10:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L7\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L8\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n11:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"pt-32 pb-20\",\"children\":[[\"$\",\"section\",null,{\"className\":\"max-w-4xl mx-auto px-6 mb-16\",\"children\":[[\"$\",\"$L9\",null,{\"href\":\"/case-studies\",\"className\":\"text-electric-blue text-sm uppercase tracking-wider mb-8 inline-block hover:text-white transition-colors\",\"children\":\"вҶҗ Back to Case Studies\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 mb-6\",\"children\":[[\"$\",\"span\",null,{\"className\":\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\",\"children\":\"HealthTech\"}],[\"$\",\"span\",null,{\"className\":\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\",\"children\":\"SaaS\"}],[\"$\",\"span\",null,{\"className\":\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\",\"children\":\"AI Application\"}]]}],[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-6xl font-display font-bold text-white mb-6 leading-tight\",\"children\":\"AI Wellness Coach Web App\"}],[\"$\",\"p\",null,{\"className\":\"text-xl text-grey leading-relaxed\",\"children\":\"Solen is a full-featured AI wellness coach providing conversational, empathetic guidance 24/7. Engineered as a complete \\\"business in a box\\\" with user authentication, subscription management, a bespoke admin dashboard, and an integrated blog CMS.\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-12 border-t border-white/10\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Client\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Solen\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Product\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Solen Platform\"}]]}],[\"$\",\"div\",null,{\"className\":\"col-span-2\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-grey text-xs uppercase tracking-wider mb-1\",\"children\":\"Deliverables\"}],[\"$\",\"p\",null,{\"className\":\"text-white font-medium\",\"children\":\"Full-Stack Web App, AI Wellness Coach, Custom CMS\"}]]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"max-w-4xl mx-auto px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"glass p-8 md:p-12 rounded-xl mb-12\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-display text-white mb-4\",\"children\":\"The Problem\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"The wellness app market is saturated with generic mood trackers and static content. Users need dynamic responses tailored to their emotional state. Moreover, running a SaaS typically requires complex DevOps, containerisation, and high server costs just to get off the ground.\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3 text-grey\",\"children\":[[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" Generic, cookie-cutter advice instead of dynamic, contextual responses.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" Complex onboarding deterring users seeking immediate help.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" High operational overhead stitching together multiple expensive SaaS tools.\"]}],[\"$\",\"li\",null,{\"className\":\"flex items-start\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-electric-blue mr-3\",\"children\":\"вң—\"}],\" JavaScript-heavy stacks requiring complex DevOps and high server costs.\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-16\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"Our Approach\"}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-6\",\"children\":\"We designed Solen with a philosophy of maximum impact with minimum architectural friction. Rather than adopting a complex microservices architecture, we opted for a highly optimised monolithic approach to keep running costs incredibly low while delivering a highly interactive, React-powered frontend.\"}],\"$L15\"]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\"]}]]}],null,\"$L1a\"]}]\n1b:[]\n12:\"$W1b\"\n13:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1c\",null,{\"children\":\"$L1d\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1e\",null,{\"children\":[\"$\",\"$1f\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L20\"}]}]}],null]}]\n21:I[484,[],\"OutletBoundary\"]\n15:[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-3 gap-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Zero-Config DB\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"SQLite3 auto-creates on first visit, making deployment as simple as FTP.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Edge Inference\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"Cloudflare AI integration for highly empathetic, edge-optimised AI coaching.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-midnight p-6 rounded-lg border border-white/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-white font-medium mb-2\",\"children\":\"Unified SaaS\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-grey\",\"children\":\"Marketing site, web app, blog, and admin tools all run from one codebase.\"}]]}]]}]\n16:[\"$\",\"h2\",null,{\"className\":\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\",\"children\":\"What We Built\"}]\n17:[\"$\",\"div\",null,{\"className\":\"space-y-12 mb-16\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"рҹӨ–\"}],\" Streaming AI Wellness Coach\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"Integrated with Cloudflare AI using server-sent events to stream responses in real-time. It features contextual memory, tracking moods and profiles via API so the coach remembers past conversations and progress.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"рҹҸў\"}],\" Comprehensive Admin Dashboard\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"A bespoke, secure control panel providing complete visibility into MRR/ARR, full CRUD capabilities for Stripe subscription management, and global configuration settings.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"рҹ“қ\"}],\" Integrated Blog CMS\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"Built-in content management system featuring rich text editing, automated SEO (meta tags, Schema.org structure), and a live Google search result preview before publishing.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-2xl text-electric-blue-lt mb-3 flex items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-3xl mr-3\",\"children\":\"рҹ’і\"}],\" Seamless Monetization\"]}],[\"$\",\"p\",null,{\"className\":\"text-grey leading-relaxed mb-4\",\"children\":\"Stripe subscription integration with automated webhook listeners securely tying Stripe products and prices directly into the local SQLite database.\"}]]}]]}]\n18:[\"$\",\"div\",null,{\"className\":\"glass p-8 md:p-12 rounded-xl mb-16\",\"children\":[[\"$\",\"h2\",nu