\"></script><script src=\"/_next/static/chunks/app/layout-c70dcc8e7d99bd2b.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/case-studies/solen/page-ba08cb273aea3701.js\" async=\"\"></script><title>Solen Case Study | Hephzibah Media</title><meta name=\"description\" content=\"How we built an AI Wellness Coach and comprehensive SaaS platform focusing on maximum impact with minimum architectural friction.\"/><link rel=\"icon\" href=\"/favicon.ico?603d046c9a6fdfbb\" type=\"image/x-icon\" sizes=\"16x16\"/><link rel=\"icon\" href=\"/icon.png\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen bg-transparent text-foreground font-sans selection:bg-electric-blue selection:text-white relative\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"fixed inset-0 z-[99999] flex flex-col items-center justify-center bg-midnight text-electric-blue font-mono\" style=\"opacity:1\"><div class=\"absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-electric-blue/10 via-midnight to-midnight opacity-50\"></div><div class=\"relative z-10 w-full max-w-md px-8\"><div class=\"flex justify-between items-end mb-2 text-xs uppercase tracking-[0.3em]\"><span>System.Boot</span><span>v2.4.0</span></div><div class=\"h-[2px] w-full bg-white/10 relative overflow-hidden\"><div class=\"absolute top-0 left-0 h-full bg-electric-blue shadow-[0_0_10px_#3b82f6]\" style=\"width:0%\"></div></div><div class=\"flex justify-between mt-4 text-[10px] text-grey uppercase tracking-widest h-4\"><span>Initializing Neural Core...</span><span class=\"text-white\">0<!-- -->%</span></div></div></div><div class=\"fixed top-0 left-0 pointer-events-none z-[9999] flex items-center justify-center mix-blend-difference\"><div class=\"relative w-8 h-8\"><img alt=\"Cursor\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Ficon.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Ficon.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Ficon.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Ficon.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Ficon.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Ficon.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Ficon.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Ficon.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Ficon.png&amp;w=3840&amp;q=75\"/></div></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"relative z-10 flex flex-col min-h-screen\"><nav class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent py-6\"><div class=\"max-w-7xl mx-auto px-6 flex items-center justify-between\"><a class=\"flex items-center gap-3 group\" href=\"/\"><div class=\"relative w-16 h-16 md:w-20 md:h-20 overflow-hidden\"><img alt=\"Hephzibah Media Logo\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain group-hover:scale-110 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2FHephzibah%20Media%20Logo.png&amp;w=3840&amp;q=75\"/></div></a><div class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[10px] font-bold text-electric-blue border border-electric-blue/30 px-3 py-1.5 rounded-full hover:bg-electric-blue hover:text-white transition-all animate-pulse\" href=\"/immersive\">Immersive Universe</a><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"#services\">Services<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/training\">Training<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/resources\">Resources<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><div class=\"relative group\"><a class=\"text-sm font-medium text-foreground/80 hover:text-electric-blue transition-colors flex items-center gap-1 uppercase tracking-wider\" href=\"/portfolio\">Company<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div><a class=\"bg-electric-blue text-white px-6 py-2 text-sm font-bold uppercase tracking-wider hover:bg-electric-blue-lt transition-colors rounded-sm\" href=\"/contact\">Get Started</a></div><button class=\"lg:hidden text-white\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main class=\"flex-grow\"><div class=\"pt-32 pb-20\"><section class=\"max-w-4xl mx-auto px-6 mb-16\"><a class=\"text-electric-blue text-sm uppercase tracking-wider mb-8 inline-block hover:text-white transition-colors\" href=\"/case-studies\">вҶҗ Back to Case Studies</a><div class=\"flex flex-wrap gap-2 mb-6\"><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">HealthTech</span><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">SaaS</span><span class=\"bg-electric-blue/10 text-electric-blue border border-electric-blue/20 text-xs px-3 py-1 rounded-full uppercase tracking-widest\">AI Application</span></div><h1 class=\"text-4xl md:text-6xl font-display font-bold text-white mb-6 leading-tight\">AI Wellness Coach Web App</h1><p class=\"text-xl text-grey leading-relaxed\">Solen is a full-featured AI wellness coach providing conversational, empathetic guidance 24/7. Engineered as a complete &quot;business in a box&quot; with user authentication, subscription management, a bespoke admin dashboard, and an integrated blog CMS.</p><div class=\"grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-12 border-t border-white/10\"><div><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Client</p><p class=\"text-white font-medium\">Solen</p></div><div><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Product</p><p class=\"text-white font-medium\">Solen Platform</p></div><div class=\"col-span-2\"><p class=\"text-grey text-xs uppercase tracking-wider mb-1\">Deliverables</p><p class=\"text-white font-medium\">Full-Stack Web App, AI Wellness Coach, Custom CMS</p></div></div></section><section class=\"max-w-4xl mx-auto px-6\"><div class=\"glass p-8 md:p-12 rounded-xl mb-12\"><h2 class=\"text-2xl font-display text-white mb-4\">The Problem</h2><p class=\"text-grey leading-relaxed mb-6\">The wellness app market is saturated with generic mood trackers and static content. Users need dynamic responses tailored to their emotional state. Moreover, running a SaaS typically requires complex DevOps, containerisation, and high server costs just to get off the ground.</p><ul class=\"space-y-3 text-grey\"><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">вң—</span> Generic, cookie-cutter advice instead of dynamic, contextual responses.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">вң—</span> Complex onboarding deterring users seeking immediate help.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">вң—</span> High operational overhead stitching together multiple expensive SaaS tools.</li><li class=\"flex items-start\"><span class=\"text-electric-blue mr-3\">вң—</span> JavaScript-heavy stacks requiring complex DevOps and high server costs.</li></ul></div><div class=\"mb-16\"><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">Our Approach</h2><p class=\"text-grey leading-relaxed mb-6\">We designed Solen with a philosophy of maximum impact with minimum architectural friction. Rather than adopting a complex microservices architecture, we opted for a highly optimised monolithic approach to keep running costs incredibly low while delivering a highly interactive, React-powered frontend.</p><div class=\"grid md:grid-cols-3 gap-6\"><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Zero-Config DB</h3><p class=\"text-sm text-grey\">SQLite3 auto-creates on first visit, making deployment as simple as FTP.</p></div><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Edge Inference</h3><p class=\"text-sm text-grey\">Cloudflare AI integration for highly empathetic, edge-optimised AI coaching.</p></div><div class=\"bg-midnight p-6 rounded-lg border border-white/5\"><h3 class=\"text-white font-medium mb-2\">Unified SaaS</h3><p class=\"text-sm text-grey\">Marketing site, web app, blog, and admin tools all run from one codebase.</p></div></div></div><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">What We Built</h2><div class=\"space-y-12 mb-16\"><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">рҹӨ–</span> Streaming AI Wellness Coach</h3><p class=\"text-grey leading-relaxed mb-4\">Integrated with Cloudflare AI using server-sent events to stream responses in real-time. It features contextual memory, tracking moods and profiles via API so the coach remembers past conversations and progress.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">рҹҸў</span> Comprehensive Admin Dashboard</h3><p class=\"text-grey leading-relaxed mb-4\">A bespoke, secure control panel providing complete visibility into MRR/ARR, full CRUD capabilities for Stripe subscription management, and global configuration settings.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">рҹ“қ</span> Integrated Blog CMS</h3><p class=\"text-grey leading-relaxed mb-4\">Built-in content management system featuring rich text editing, automated SEO (meta tags, Schema.org structure), and a live Google search result preview before publishing.</p></div><div><h3 class=\"text-2xl text-electric-blue-lt mb-3 flex items-center\"><span class=\"text-3xl mr-3\">рҹ’і</span> Seamless Monetization</h3><p class=\"text-grey leading-relaxed mb-4\">Stripe subscription integration with automated webhook listeners securely tying Stripe products and prices directly into the local SQLite database.</p></div></div><div class=\"glass p-8 md:p-12 rounded-xl mb-16\"><h2 class=\"text-2xl font-display text-white mb-6\">Results &amp; Impact</h2><div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\"><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">60s</div><div class=\"text-xs text-grey uppercase tracking-wider\">Deployment Time</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">Zero</div><div class=\"text-xs text-grey uppercase tracking-wider\">DevOps Config</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">Edge</div><div class=\"text-xs text-grey uppercase tracking-wider\">AI Inference</div></div><div class=\"text-center\"><div class=\"text-3xl font-display text-electric-blue font-bold mb-1\">100%</div><div class=\"text-xs text-grey uppercase tracking-wider\">Self-Contained</div></div></div></div><div><h2 class=\"text-3xl font-display text-white mb-8 border-l-4 border-electric-blue pl-4\">The Architecture</h2><div class=\"bg-black/50 border border-white/10 p-6 rounded-lg font-mono text-sm text-electric-blue-lt overflow-x-auto whitespace-pre\">в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ                  Frontend App                      в”Ӯ\nв”Ӯ        React 18 (Loaded via CDN for Zero-Build)    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n                       в”Ӯ\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ                 Backend Server                     в”Ӯ\nв”Ӯ    PHP 8.1+ В· Apache (.htaccess) В· Secure Proxy    в”Ӯ\nв”Ӯ    (Monolithic SaaS processing &amp; API router)       в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n                       в”Ӯ         в”Ӯ\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”җ    в”Ңв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ     SQLite3 DB         в”Ӯ    в”Ӯ Cloudflare AI        в”Ӯ\nв”Ӯ   (Zero Config DB)     в”Ӯ    в”Ӯ (Streaming Engine)   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ    в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ</div></div></section></div><!--$--><!--/$--></main><footer class=\"bg-midnight-mid border-t border-white/10 pt-20 pb-10\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\"><div class=\"space-y-6\"><a class=\"flex items-center gap-3 group\" href=\"/\"><div class=\"relative w-8 h-8 overflow-hidden\"><img alt=\"Hephzibah Media Logo\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain group-hover:scale-110 transition-tra