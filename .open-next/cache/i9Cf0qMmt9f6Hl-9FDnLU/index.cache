orm:translateY(20px)\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/20 transition-colors\"></div><div class=\"relative z-10\"><div class=\"w-12 h-12 flex items-center justify-center bg-midnight-lt border border-white/10 text-electric-blue mb-6 group-hover:scale-110 transition-transform duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shopping-bag\" aria-hidden=\"true\"><path d=\"M16 10a4 4 0 0 1-8 0\"></path><path d=\"M3.103 6.034h17.794\"></path><path d=\"M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z\"></path></svg></div><h3 class=\"text-xl font-bold text-white mb-4 group-hover:text-electric-blue transition-colors\">E-commerce</h3><p class=\"text-grey text-sm leading-relaxed mb-8 opacity-80 group-hover:opacity-100 transition-opacity\">Paystack/Flutterwave integrated stores with automated inventory and order management systems.</p><a class=\"inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-electric-blue hover:text-white transition-colors\" href=\"/services/ecommerce\">Learn More <span class=\"group-hover:translate-x-1 transition-transform\">→</span></a></div><div class=\"absolute bottom-0 left-0 h-[2px] bg-electric-blue w-0 group-hover:w-full transition-all duration-700\"></div></div><div class=\"group relative bg-midnight-mid border border-white/5 p-8 hover:border-electric-blue/50 transition-all duration-500 hover:-translate-y-2 overflow-hidden\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute top-0 right-0 w-32 h-32 bg-electric-blue/5 blur-3xl group-hover:bg-electric-blue/20 transition-colors\"></div><div class=\"relative z-10\"><div class=\"w-12 h-12 flex items-center justify-center bg-m